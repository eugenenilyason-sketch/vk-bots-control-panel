# ============= DATABASE =============
POSTGRES_PASSWORD=your_secure_postgres_password
JWT_SECRET=your_secure_jwt_secret
NC_JWT_SECRET=your_secure_nc_jwt_secret
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@supabase:5432/vk_bot

# ============= VK OAuth =============
VK_CLIENT_ID=your_vk_client_id
VK_CLIENT_SECRET=your_vk_client_secret
VK_REDIRECT_URI=https://lianium.ru

# ============= N8N (Optional) =============
N8N_HOST=n8n.yourdomain.com
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=your_n8n_admin_password
N8N_JWT_SECRET=your_secure_n8n_jwt_secret
N8N_API_KEY=your_n8n_api_key

# ============= NocoDB (Optional) =============
NOCODB_HOST=nocodb.yourdomain.com
NOCODB_API_KEY=your_nocodb_api_key

# ============= Redis =============
REDIS_PASSWORD=your_secure_redis_password

# ============= Application =============
NODE_ENV=production
FRONTEND_URL=https://lianium.ru
BACKEND_URL=http://vk-backend:4000

# ============= Session =============
SESSION_DRIVER=file

# ============================================
# 💳 PAYMENT METHODS - НАСТРАИВАЮТСЯ В АДМИНКЕ
# ============================================
# Настройки платёжных методов теперь хранятся в БД
# и управляются через админ-панель:
# /admin/payment-methods
#
# Для каждого метода можно настроить:
# - API URL
# - Webhook URL
# - API Key / Secret (шифруются)
# - Merchant ID
# - Таймаут
# - Валюту
# - Тестовый режим
# ============================================
