# Laravel .gitignore

/vendor/
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log

# Environment
.env
.env.local
.env.*.local

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Storage & Cache
storage/*.key
bootstrap/cache/*.php
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
storage/logs/*
!storage/framework/cache/.gitignore
!storage/framework/sessions/.gitignore
!storage/framework/views/.gitignore
!storage/logs/.gitignore

# Build
/public/hot
/public/storage
.mix.lock

# Testing
/.phpunit.result.cache
/coverage
vendor/

# NPM
npm-debug.log
yarn-error.log

# Sail
docker-compose.override.yml
