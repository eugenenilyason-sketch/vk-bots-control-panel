# ============================================
# VK Neuro-Agents Backend - Environment Config
# ============================================
# Copy this file to .env and fill in the values

# ============================================
# Application
# ============================================
NODE_ENV=production
PORT=4000

# ============================================
# Database (PostgreSQL via Prisma)
# ============================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:your_postgres_password@supabase:5432/vk_bot

# ============================================
# JWT Authentication
# ============================================
# Must match the JWT_SECRET in root .env file
JWT_SECRET=your_jwt_secret_key_here

# ============================================
# VK ID OAuth
# ============================================
# Get these from https://dev.vk.com/
VK_CLIENT_ID=your_vk_client_id
VK_CLIENT_SECRET=your_vk_client_secret
VK_REDIRECT_URI=https://yourdomain.com

# Optional: VK Service Token (for server-side API calls)
# VK_SERVICE_TOKEN=

# ============================================
# Redis (Optional - for caching/sessions)
# ============================================
REDIS_HOST=redis
REDIS_PASSWORD=your_redis_password
REDIS_PORT=6379

# ============================================
# CORS (Optional)
# ============================================
# Comma-separated list of allowed origins
# CORS_ORIGINS=https://yourdomain.com,http://localhost:3000

# ============================================
# Logging
# ============================================
LOG_LEVEL=info
# LOG_FILE=logs/app.log

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
