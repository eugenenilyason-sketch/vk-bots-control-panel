  "workflows": {
    "codeReview": {
      "trigger": "При изменении кода (PR, commit)",
      "roles": ["Full-Stack Developer", "QA Engineer"],
      "steps": [
        "Анализ изменений и diff",
        "Проверка безопасности (security scan)",
        "Проверка производительности (performance impact)",
        "Тестирование функциональности",
        "Фидбек и рекомендации по улучшению"
      ]
    },
    "featureDevelopment": {
      "trigger": "Новая функциональность или feature request",
      "roles": ["Solution Architect", "Full-Stack Developer", "Frontend UI/UX Designer"],
      "steps": [
        "Проектирование архитектуры фичи",
        "Database schema изменения (если нужно)",
        "Backend API реализация",
        "Frontend компонент реализация",
        "UI/UX polish и theming",
        "Написание тестов",
        "Документирование"
      ]
    },
    "securityAudit": {
      "trigger": "Перед релизом или по расписанию",
      "roles": ["Solution Architect", "DevOps Engineer", "QA Engineer"],
      "steps": [
        "Проверка CORS и security headers",
        "Валидация входных данных (input sanitization)",
        "Проверка логгирования (no sensitive data)",
        "Анализ уязвимостей (dependencies scan)",
        "Тестирование на проникновение (pentest)",
        "OAuth flow проверка"
      ]
    },
